# ============================================
# Kamal Saad E-commerce - Environment Variables
# ============================================

# Database
DB_PASSWORD="your-strong-db-password"

# PgBouncer (Connection Pooler)
# Use this URL when PgBouncer is running (port 6432)
DATABASE_URL_WITH_POOLER=postgresql://kamal:${DB_PASSWORD}@localhost:6432/kamal_saad?sslmode=prefer&pgbouncer=true

# Direct connection (without pooler)
DATABASE_URL=postgresql://kamal:${DB_PASSWORD}@localhost:5432/kamal_saad

# Authentication
AUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_URL="https://your-domain.com"

# ═══════════════════════════════════════════════
#  IMAGE STORAGE — اختر خلفية واحدة فقط
# ═══════════════════════════════════════════════
#
#  الخيار 1: Cloudflare R2 (مُوصى به — الأوفر)
#  التكلفة: ~$0.50/شهر لـ 10,000 منتج
#  CDN مجاني غير محدود + بدون رسوم بيانات خروج
#
# الخطوات:
#  1. سجّل في cloudflare.com → R2 Object Storage
#  2. أنشئ bucket جديد (مثال: kamal-saad-assets)
#  3. Settings → R2 API → Create API Token
#  4. Settings → Public Access → Enable R2.dev subdomain (أو ربط domain مخصص)
#
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET="kamal-saad-assets"
R2_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
R2_REGION="auto"
# R2_PUBLIC_URL = رابط CDN المجاني أو domain مخصص
# مثال مع R2.dev: https://kamal-saad-assets.r2.dev
# مثال مع domain مخصص: https://assets.yourdomain.com
R2_PUBLIC_URL="https://kamal-saad-assets.r2.dev"

#  الخيار 2: Local Storage (مجاني — للتطوير)
#  الصور تُخزّن في public/uploads/ تلقائياً
#  لا تحتاج أي متغيرات إضافية — يعمل تلقائياً إذا لم تُعدّ R2
# STORAGE_BACKEND=local

#  الخيار 3: Cloudinary (للصور القديمة فقط — توافقية)
#  لا يُنصح به للمشاريع الجديدة (25 رصيد/يوم مجاناً، $89/شهر Pro)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Google OAuth (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Paymob Payment Gateway
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_CARD_INTEGRATION_ID="card-integration-id"
PAYMOB_WALLET_INTEGRATION_ID="wallet-integration-id"
PAYMOB_KIOSK_INTEGRATION_ID="kiosk-integration-id"
PAYMOB_IFRAME_ID="iframe-id"
PAYMOB_HMAC_SECRET="your-hmac-secret-key"
