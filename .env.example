# ============================================
# Kamal Saad E-commerce - Environment Variables
# ============================================

# Database
DB_PASSWORD="your-strong-db-password"

# PgBouncer (Connection Pooler)
# Use this URL when PgBouncer is running (port 6432)
DATABASE_URL_WITH_POOLER=postgresql://kamal:${DB_PASSWORD}@localhost:6432/kamal_saad?sslmode=prefer&pgbouncer=true

# Direct connection (without pooler)
DATABASE_URL=postgresql://kamal:${DB_PASSWORD}@localhost:5432/kamal_saad

# Authentication
AUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_URL="https://your-domain.com"

# Cloudinary (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Google OAuth (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Paymob Payment Gateway
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_CARD_INTEGRATION_ID="card-integration-id"
PAYMOB_WALLET_INTEGRATION_ID="wallet-integration-id"
PAYMOB_KIOSK_INTEGRATION_ID="kiosk-integration-id"
PAYMOB_IFRAME_ID="iframe-id"
PAYMOB_HMAC_SECRET="your-hmac-secret-key"
