# ============================================
# كمال سعد — متغيرات البيئة للإنتاج
# ============================================
# انسخ هذا الملف إلى .env.production واملأ القيم
# أو ضع المتغيرات مباشرة في Coolify → Environment
# ============================================

# ─── الخادم ───
NODE_ENV=production
NEXTAUTH_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── الأمان ───
# استخدم: openssl rand -base64 32
AUTH_SECRET=ChangeThisToARandom32CharString12345
NEXTAUTH_SECRET=ChangeThisToARandom32CharString12345

# ─── قاعدة البيانات (PostgreSQL) ───
# إذا استخدمت Coolify's PostgreSQL:
DATABASE_URL=postgresql://kamal:YOUR_PASSWORD@db:5432/kamal_saad

# إذا استخدمت Neon (خارجي):
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

POSTGRES_USER=kamal
POSTGRES_PASSWORD=ChangeThisToAStrongPassword
POSTGRES_DB=kamal_saad

# ─── صور Cloudflare R2 (الأوفر) ───
R2_ACCESS_KEY_ID=your-r2-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=kamal-saad-assets
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Cloudinary (للصور القديمة — اختياري) ───
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Google OAuth (اختياري) ───
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Paymob الدفع (اختياري) ───
PAYMOB_API_KEY=your-paymob-key
PAYMOB_CARD_INTEGRATION_ID=card-int-id
PAYMOB_WALLET_INTEGRATION_ID=wallet-int-id
PAYMOB_KIOSK_INTEGRATION_ID=kiosk-int-id
PAYMOB_IFRAME_ID=iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret
